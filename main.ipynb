    "# Créer code_commune complet (département + commune sur 3 chiffres)\n",
    "df[\"code_commune\"] = df[\"code_departement\"].astype(str) + df[\"code_commune\"].astype(str).str.zfill(3)\n",
    "\n",
    "# Créer la colonne candidat (prenom + nom)\n",

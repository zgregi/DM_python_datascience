   "source": [
    "# Question 5 : score départemental vs national (style Question 4)\n",
    "\n",
    "# Ajouter les scores et votes nationaux au dataframe départemental\n",
    "score_departements[\"score_national\"] = score_departements[\"candidat\"].map(\n",
    "scores.set_index(\"Candidat\")[\"Score (% votes exprimés)\"].str.replace(\" %\",\"\").astype(float)\n",
    ")\n",
    "score_departements[\"votes_national\"] = score_departements[\"candidat\"].map(\n",
    "scores.set_index(\"Candidat\")[\"Nombre votes (total)\"]\n",
    ")\n",
    "\n",
    "# Réordonner les colonnes\n",
    "score_departements = score_departements[\n",
    "[\"code_departement\", \"candidat\", \"votes_departement\", \"score_departement\", \"votes_national\", \"score_national\"]\n",
    "]\n",
    "\n",
    "GT(score_departements.head()) \\\n",
    ".tab_header(title=\"Score départemental vs national (extrait)\") \\\n",
    ".cols_label(\n",
    "    code_departement=\"Département\",\n",
    "    candidat=\"Candidat\",\n",
    "    votes_departement=\"Votes Département\",\n",
    "    score_departement=\"Score Département\",\n",
    "    votes_national=\"Votes National\",\n",
    "    score_national=\"Score National\"\n",
    ") \\\n",
    ".fmt_number(columns=[\"votes_departement\",\"votes_national\"], decimals=0, sep_mark=\" \") \\\n",
    ".fmt_percent(columns=[\"score_departement\",\"score_national\"], decimals=2, scale_values=False)"
   ]
  },
